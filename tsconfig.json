{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",           // ← IMPORTANTE: pasta de saída
    "rootDir": "./src",            // ← IMPORTANTE: pasta de origem
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "./src",
  },
  "include": ["src/**/*"],         // ← Incluir tudo em src
  "exclude": ["node_modules", "dist"]  // ← Excluir node_modules e dist
}